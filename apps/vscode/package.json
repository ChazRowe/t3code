{
  "name": "t3-code",
  "displayName": "T3 Code",
  "version": "0.0.27",
  "private": true,
  "description": "T3 Code session experience inside VSCode.",
  "publisher": "t3tools",
  "type": "module",
  "main": "./dist/extension.cjs",
  "scripts": {
    "build:bundle": "vp pack",
    "build:webview": "vp build --config webview/vite.config.ts",
    "dev:bundle": "vp pack --watch",
    "stage:server": "node scripts/stageServerDist.ts",
    "prepack": "pnpm run stage:server",
    "vscode:prepublish": "vp pack && pnpm run build:webview && pnpm run stage:server",
    "package:vsix": "vsce package --no-dependencies",
    "smoke-test": "node scripts/smokeSupervisor.ts && pnpm run build:webview && node scripts/smokeChatWebview.ts",
    "typecheck": "tsgo --noEmit",
    "test": "vp test run"
  },
  "dependencies": {
    "@t3tools/contracts": "workspace:*",
    "@t3tools/web": "workspace:*"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "catalog:",
    "@types/vscode": "^1.90.0",
    "@vitejs/plugin-react": "^6.0.0",
    "@vscode/vsce": "^3.7.1",
    "tailwindcss": "^4.0.0",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "contributes": {
    "commands": [
      {
        "command": "t3code.openChat",
        "title": "T3 Code: Open Chat",
        "category": "T3 Code"
      },
      {
        "command": "t3code.showStatus",
        "title": "T3 Code: Status",
        "category": "T3 Code"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "t3code",
          "title": "T3 Code",
          "icon": "media/t3code.svg"
        }
      ]
    },
    "views": {
      "t3code": [
        {
          "type": "webview",
          "id": "t3code.chat",
          "name": "Chat"
        }
      ]
    }
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "extensionKind": [
    "workspace"
  ],
  "engines": {
    "node": "^24.13.1",
    "vscode": "^1.90.0"
  }
}
