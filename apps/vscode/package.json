{
  "name": "t3-code",
  "displayName": "T3 Code",
  "version": "0.0.27",
  "private": true,
  "description": "T3 Code session experience inside VSCode.",
  "publisher": "t3tools",
  "type": "module",
  "main": "./dist/extension.cjs",
  "scripts": {
    "build:bundle": "vp pack",
    "dev:bundle": "vp pack --watch",
    "stage:server": "node scripts/stageServerDist.ts",
    "prepack": "pnpm run stage:server",
    "vscode:prepublish": "vp pack && pnpm run stage:server",
    "package:vsix": "vsce package --no-dependencies",
    "smoke-test": "node scripts/smokeSupervisor.ts",
    "typecheck": "tsgo --noEmit",
    "test": "vp test run"
  },
  "dependencies": {
    "@t3tools/contracts": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.7.1",
    "vite-plus": "catalog:"
  },
  "contributes": {
    "commands": [
      {
        "command": "t3code.showStatus",
        "title": "T3 Code: Status",
        "category": "T3 Code"
      }
    ]
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "extensionKind": [
    "workspace"
  ],
  "engines": {
    "node": "^24.13.1",
    "vscode": "^1.90.0"
  }
}
